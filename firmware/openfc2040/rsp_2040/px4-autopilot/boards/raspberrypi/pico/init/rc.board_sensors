#!/bin/sh
#
# OpenFC2040 board specific sensors init
#------------------------------------------------------------------------------

# Start board ADC for battery monitoring
board_adc start

# Start LSM6DS3 IMU on SPI1
lsm6ds3 start -s -b 1

# Start DPS310 barometer on SPI1
dps310 start -s -b 1

# Start GPS on UART1
gps start -d /dev/ttyS1

# Start RC input
rc_input start -d /dev/ttyS3
