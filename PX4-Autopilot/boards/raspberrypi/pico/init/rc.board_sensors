#!/bin/sh
#
# board specific sensors init
#------------------------------------------------------------------------------

# 1. Start ADC
# Necessary for Battery Voltage (GPIO27) and Current (GPIO28) monitoring
board_adc start

# 2. Start IMU: LSM6DS3TR-C (native driver support)
# -s : Internal SPI bus
# -R : Rotation (0 = ROTATION_NONE)
lsm6ds3 start -s -R 0

# 3. Start Barometer: DPS310
# -s : Internal SPI bus
dps310 start -s