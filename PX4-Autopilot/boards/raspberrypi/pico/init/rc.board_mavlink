#!/bin/sh
#
# board specific MAVLink startup script.
#------------------------------------------------------------------------------

# MAVLink on USB CDC ACM only
# Mode: minimal - only essential streams (attitude, position, GPS, battery, sys_status)
# Lower CPU impact than 'normal' mode (fewer streams, lower rates)
mavlink start -d /dev/ttyACM0 -b 115200 -m normal -r 6000
